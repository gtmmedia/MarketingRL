# Inference script configuration (inference.py)
# Optional: docker image used to boot the benchmark environment.
IMAGE_NAME=your-space-or-local-image

# Authentication
# Preferred for Hugging Face Router/OpenAI-compatible endpoints.
HF_TOKEN=your_hf_token_here
# Optional fallback if HF_TOKEN is not set.
API_KEY=

# OpenAI-compatible client settings
API_BASE_URL=https://router.huggingface.co/v1
MODEL_NAME=Qwen/Qwen2.5-72B-Instruct

# Benchmark/task selection
MY_ENV_V4_TASK=echo
MY_ENV_V4_BENCHMARK=my_env_v4

# Local imports for this repository layout
PYTHONPATH=src
